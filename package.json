{
  "name": "@microsoft/just-repo",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/just"
  },
  "workspaces": {
    "packages": [
      "packages/*",
      "scripts"
    ]
  },
  "scripts": {
    "api": "lage api",
    "api:update": "lage api:update",
    "build": "lage build",
    "postbuild": "node ./scripts/copyReadme.js",
    "change": "beachball change",
    "checkchange": "beachball check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "release": "beachball publish -y",
    "release:canary": "beachball canary -y",
    "start": "lage start",
    "test": "lage test",
    "prelint": "syncpack list-mismatches",
    "lint": "eslint packages --ext .ts,.js"
  },
  "engines": {
    "node": ">=22.18.0 || >=24"
  },
  "devDependencies": {
    "@jest/globals": "^29.5.0",
    "@microsoft/api-extractor": "7.52.9",
    "@types/fs-extra": "^11.0.0",
    "@types/jest": "^29.4.0",
    "@types/mock-fs": "^4.13.1",
    "@types/node": "^22.0.0",
    "@types/semver": "^7.3.13",
    "@typescript-eslint/eslint-plugin": "^5.54.1",
    "@typescript-eslint/parser": "^5.54.1",
    "beachball": "^2.65.5",
    "eslint": "^8.35.0",
    "jest": "^29.5.0",
    "lage": "^2.15.12",
    "mock-fs": "^5.2.0",
    "prettier": "~3.8.0",
    "syncpack": "^9.0.0",
    "ts-jest": "~29.2.5",
    "typescript": "~4.5.0"
  },
  "resolutions": {
    "es5-ext": "0.10.53",
    "kind-of": "^6.0.3",
    "@types/glob/@types/minimatch": "^3.0.0",
    "syncpack/minimatch": "^6.2.3",
    "@microsoft/api-extractor/minimatch": "^3.1.5",
    "@microsoft/api-extractor/lodash": "^4.18.1",
    "@types/chokidar/chokidar": "^3.0.0",
    "browserslist/node-releases": "2.0.44",
    "@types/node@*": "^22.0.0"
  },
  "rationale": {
    "devDependencies": {
      "@microsoft/api-extractor": "Pin to newest version that supports node 14"
    },
    "resolutions": {
      "@types/glob/@types/minimatch": "pin to installed minimatch version, not *",
      "syncpack/minimatch": "unpin to fix security issue",
      "@microsoft/api-extractor/minimatch": "unpin to fix security issue",
      "@microsoft/api-extractor/lodash": "unpin to fix security issue",
      "@types/chokidar/chokidar": "pin to version matching other chokidar deps, not *",
      "browserslist/node-releases": "node 14 compat"
    }
  },
  "syncpack": {
    "dependencyTypes": [
      "dev",
      "prod"
    ]
  }
}
