{
  "name": "just-scripts",
  "version": "3.0.0-alpha.0",
  "description": "Build presets for Node and browser projects",
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/just",
    "directory": "packages/just-scripts"
  },
  "homepage": "https://microsoft.github.io/just/",
  "license": "MIT",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "bin": "bin/just-scripts.js",
  "scripts": {
    "api": "yarn run -T api-extractor run",
    "api:update": "yarn run -T api-extractor run --local",
    "build": "yarn run -T tsc",
    "lint": "yarn run -T eslint --color --max-warnings=0 src",
    "prepack": "cp .npmignore lib/.npmignore",
    "start": "yarn run -T tsc -w --preserveWatchOutput",
    "start-test": "yarn run -T jest --watch",
    "test": "yarn run -T jest",
    "test:update": "yarn run -T jest --updateSnapshot"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "dependencies": {
    "chalk": "^4.0.0",
    "cross-spawn": "^7.0.6",
    "fs-extra": "^11.0.0",
    "glob": "^13.0.6",
    "just-task": "workspace:^",
    "run-parallel-limit": "^1.0.6",
    "supports-color": "^8.1.0",
    "webpack-merge": "^6.0.1"
  },
  "devDependencies": {
    "@microsoft/just-internal-scripts": "workspace:^",
    "@types/cross-spawn": "^6.0.6",
    "@types/run-parallel-limit": "^1.0.0",
    "@types/supports-color": "^8.1.1",
    "@types/webpack": "^4.41.33",
    "async-done": "^2.0.0",
    "esbuild": "^0.28.0"
  },
  "files": [
    "bin",
    "lib"
  ]
}
