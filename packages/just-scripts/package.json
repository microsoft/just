    "webpack": "^5.0.0",
    "webpack-cli": ">=5",
    "webpack-dev-server": ">=4"
  },
  "rationale": {
    "peerDependencies": {
      "postcss": "align other deps on 8+, released 2020",
      "webpack": "align other deps on 5+, released 2020",
      "@microsoft/api-extractor": "newline option introduced in 7.6.0; stricter range due to API usage",
      "@microsoft/load-themed-styles": "peer of @microsoft/loader-load-themed-styles 2.x",
      "@microsoft/loader-load-themed-styles": "1.x released 2017; 2.x released 2022",
      "autoprefixer": "10.x released 2020 for postcss 8",
      "css-loader": "6.x released 2021 for webpack 5",
      "esbuild": "0.25 had security fix; open range due to rapid releases",
      "eslint": "8.x released 2021; older versions well out of support",
      "file-loader": "3.x released 2018 for webpack 5; 4.x 2019; 5.x 2019 esModule true by default",
      "fork-ts-checker-webpack-plugin": "7.x released 2022 for webpack 5; earlier might be fine",
      "html-webpack-plugin": "5.x released 2021 for webpack 5",
      "jest": "somewhat arbitary; 29 released 2022",
      "node-sass": "9.x released 2023; deprecated 2024; users should migrate to sass",
      "postcss-clean": "only version",
      "postcss-loader": "5.x released 2021 for webpack 5",
      "postcss-rtl": "2.x released 2022 for postcss 8",
      "prettier": "3.x released 2023; still allow 2.x",
      "sass": "1.x released 2018",
      "sass-loader": "11.x released 2021 for webpack 5",
      "style-loader": "2.x released 2020; still seeing usage",
      "tar-fs": "2.x released 2019; stricter range due to API usage",
      "ts-loader": "8.x released 2020; still seeing usage",
      "ts-node": "8.x released 2019; still seeing usage",
      "typescript": "could allow some 4.x; 7.x likely to be breaking",
      "webpack-cli": "5.x released 2022 for webpack 5",
      "webpack-dev-server": "required for webpack serve; 4.x released 2021 supports webpack 5"
    }
  },
